[Desktop Entry]
Type=Service
Name=Claude & Web Search
Comment=Auto-shows "Ask Claude" / "Search the web" after a pause; instant via c …, s …
Icon=claude
X-KDE-ServiceTypes=Plasma/Runner
X-KDE-PluginInfo-Name=claudesearch
X-KDE-PluginInfo-Version=1.0
X-KDE-PluginInfo-License=MIT
X-KDE-PluginInfo-EnabledByDefault=true
X-Plasma-API=DBus
X-Plasma-DBusRunner-Service=dev.corey.krunner.claude
X-Plasma-DBusRunner-Path=/krunner
X-Plasma-Request-Actions-Once=true
X-Plasma-Runner-Min-Letter-Count=2
X-Plasma-Runner-Weak-Results=true
X-Plasma-Runner-Syntaxes=:q:
X-Plasma-Runner-Syntax-Descriptions=Ask Claude or web-search :q: (instant: c :q: or s :q:)
