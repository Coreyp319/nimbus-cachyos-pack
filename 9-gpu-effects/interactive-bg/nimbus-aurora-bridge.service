[Unit]
Description=Nimbus Aurora window-reactivity bridge
Documentation=man:systemd.service(5)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/.local/share/nimbus-aurora/aurora-bridge.py
Restart=on-failure
RestartSec=2
# It only writes a small JSON into the runtime dir; keep it unprivileged + tidy.
Nice=5

[Install]
WantedBy=graphical-session.target
